.viz-container {
  max-width: 1100px;
  margin: 24px auto;
  padding: 0 16px;
}

.subtitle {
  color: #666;
  margin-top: -6px;
}

.flow-wrapper {
  display: grid;
  grid-template-columns: repeat(9, 1fr);
  gap: 12px;
  align-items: center;
  margin: 24px 0 32px;
}

/* 5 steps + 4 arrows = 9 columns */
.flow-step {
  grid-column: span 2;
  background: #fff;
  border: 1px solid #e6e6e6;
  border-radius: 12px;
  padding: 16px;
  min-height: 130px;
  box-shadow: 0 1px 2px rgba(0,0,0,0.04);
}

.flow-icon {
  font-size: 26px;
}

.flow-title {
  font-weight: 700;
  margin: 6px 0 4px;
}

.flow-desc {
  color: #666;
  font-size: 0.95rem;
  line-height: 1.35;
}

.arrow {
  grid-column: span 1;
  text-align: center;
  font-size: 24px;
  color: #999;
}

.panel-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.panel {
  background: #fff;
  border: 1px solid #e6e6e6;
  border-radius: 12px;
  padding: 16px;
}

.btn {
  display: inline-block;
  margin-right: 8px;
  margin-bottom: 8px;
  padding: 8px 12px;
  border-radius: 8px;
  border: 1px solid #ddd;
  background: #f8f8f8;
  cursor: not-allowed; /* enabled in next step */
}

.status-list {
  list-style: none;
  padding-left: 0;
  margin: 0;
}

.hint {
  color: #777;
  margin-top: 16px;
  font-size: 0.95rem;
}

/* mobile */
@media (max-width: 900px) {
  .flow-wrapper {
    grid-template-columns: 1fr;
  }
  .flow-step, .arrow { grid-column: span 1; }
  .arrow { transform: rotate(90deg); }
  .panel-row { grid-template-columns: 1fr; }
}
